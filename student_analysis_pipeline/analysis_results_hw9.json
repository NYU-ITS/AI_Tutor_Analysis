  "practice_problems": [
    {
      "problem_number": 1,
      "topic": "Limits",
      "question": "Evaluate $\\lim_{x\\to\\infty} \\frac{5x^2 + 3x}{2x^2 + 7x + 1}.$",
      "hint": "Divide numerator and denominator by the highest power of $x$ in the denominator.",
      "answer": "The limit is $\\frac{5}{2}$."
    },
    {
      "problem_number": 2,
      "topic": "Limits",
      "question": "Evaluate $\\lim_{x\\to 2} \\frac{x^3 - 8}{x^2 - 4}.$",
      "hint": "Factorize both numerator and denominator to simplify the expression.",
      "answer": "The limit is $6$."
    },
    {
      "problem_number": 3,
      "topic": "Critical Numbers",
      "question": "Find all critical numbers for the function $f(x) = x^3 - 3x^2 + 2x.$",
      "hint": "Find $f'(x)$ and solve $f'(x) = 0$ to locate critical numbers.",
      "answer": "The critical numbers are $x = 0$, $x = 1$, and $x = 2$."
    },
    {
      "problem_number": 4,
      "topic": "First Derivative Test",
      "question": "Use the First Derivative Test to determine the local extrema of $f(x) = x^3 - 3x^2 + 2x.$",
      "hint": "Analyze the sign of $f'(x)$ around the critical numbers.",
      "answer": "Local maximum at $x = 1$, local minimum at $x = 2$."
    },
    {
      "problem_number": 5,
      "topic": "Absolute Extrema",
      "question": "Find the absolute extrema of $f(x) = x^2 - 4x$ on the interval $[0, 5].$",
      "hint": "Evaluate $f(x)$ at the critical numbers and endpoints of the interval.",
      "answer": "Absolute minimum at $x = 2$ ($f(2) = -4$), absolute maximum at $x = 5$ ($f(5) = 5$)."
    }
  ],
